{
  "name": "helpers-inventory-system",
  "private": true,
  "version": "1.0.1",
  "description": "Protected desktop inventory and sales management system",
  "author": "Helpers Technologies",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "cross-env ELECTRON_RUN_AS_NODE= ELECTRON_RENDERER_URL=http://127.0.0.1:5173 concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "dist:win": "npm run build && electron-builder --win nsis",
    "license:init": "node scripts/generate-license.cjs --init-keypair",
    "license:generate": "node scripts/generate-license.cjs",
    "license:studio": "node scripts/license-studio.cjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.helperstechnologies.inventory",
    "productName": "Helpers Inventory",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/icon.ico",
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "!**/scripts/**",
      "!**/.license/**",
      "!**/*.pem",
      "!**/*.md",
      "!**/.git/**",
      "!**/.gitignore",
      "!**/Missing features.md"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3-multiple-ciphers/**/*",
      "node_modules/argon2/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "argon2": "^0.44.0",
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.6",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "terser": "^5.47.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "wait-on": "^9.0.10"
  }
}
